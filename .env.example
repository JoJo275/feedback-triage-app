# =============================================================================
# .env.example — feedback-triage-app
# =============================================================================
# Copy to .env and fill in real values. .env is gitignored.
#
# Variables consumed by:
#   - src/feedback_triage/config.py (pydantic-settings)
#   - docker-compose.yml (compose interpolation)
#   - alembic.ini (DATABASE_URL only)
# =============================================================================

# ── Application ───────────────────────────────────────────────
# development | production. Controls debug, log format, and 500 response
# verbosity (see spec §"Validation, Error Handling, Logging").
APP_ENV=development

# trace | debug | info | warning | error | critical
LOG_LEVEL=info

# Port the app listens on. Railway overrides with $PORT.
PORT=8000

# Comma-separated list of allowed CORS origins. Leave empty to disable CORS.
# Example: http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGINS=

# Pagination defaults. Spec caps limit at PAGE_SIZE_MAX.
PAGE_SIZE_DEFAULT=20
PAGE_SIZE_MAX=100

# ── Database ──────────────────────────────────────────────────
# SQLAlchemy URL. The app normalises postgres:// → postgresql+psycopg://
# at load time (Railway emits the legacy scheme).
DATABASE_URL=postgresql+psycopg://feedback:CHANGE_ME@localhost:5432/feedback

# ── docker-compose only ───────────────────────────────────────
# Used by the `db` service to provision the Postgres container.
# Keep in sync with the user/password/db inside DATABASE_URL above.
POSTGRES_USER=feedback
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=feedback
POSTGRES_PORT=5432
APP_PORT=8000

# ── Email / Resend (v2.0; ADR 061) ────────────────────────────
# Required in production when FEATURE_AUTH=true and RESEND_DRY_RUN=0.
# In dev/test, DRY_RUN=1 short-circuits the HTTP call and writes a
# synthetic ``email_log`` row instead.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=no-reply@signalnest.app
RESEND_DRY_RUN=1
RESEND_TIMEOUT_SECONDS=5
RESEND_MAX_RETRIES=2
# Standard-Webhooks signing secret (whsec_<base64>). When empty,
# /api/v1/webhooks/resend is mounted but returns 503 — flipping a
# secret in production enables ingestion without a redeploy.
RESEND_WEBHOOK_SECRET=

# ── Build metadata (optional) ─────────────────────────────────
# Inject when building the container outside a git checkout (e.g. CI).
# VERSION=0.1.0+abcdef0
