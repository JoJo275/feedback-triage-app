// Dev container for feedback-triage-app.
//
// Uses Microsoft's Python devcontainer image (Debian + Python 3.13)
// and adds the small set of host tools the project needs at the dev
// surface: uv (env + lockfile), Task (task runner), Docker-in-Docker
// (Postgres compose stack), and the GitHub CLI. Project dependencies
// install on first attach via ``uv sync --frozen --extra dev`` so the
// CI dev-container build (.github/workflows/devcontainer-build.yml)
// can import ``feedback_triage`` immediately.
{
  "name": "feedback-triage-app",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "features": {
    // Pin the major version of every feature; the underlying images
    // refresh on rebuild without forcing a config edit.
    //
    // ``docker-outside-of-docker`` mounts the host Docker socket
    // instead of running a daemon inside the container. This avoids
    // the heavy apt setup that the full ``docker-in-docker`` feature
    // performs (which intermittently breaks on upstream Yarn-repo
    // GPG-key rotations during CI builds, NO_PUBKEY 62D54FD4003F6525)
    // while still letting devs run ``docker compose`` from the
    // container against their host's daemon.
    //
    // ``uv`` and ``task`` are installed in postCreateCommand because
    // their ghcr.io feature manifests are not publicly resolvable
    // from CI runners (anonymous ghcr.io requests return 403).
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "UV_LINK_MODE": "copy"
  },
  // ``uv sync`` provisions the project's virtualenv from uv.lock and
  // makes ``feedback_triage`` importable. ``pre-commit install`` wires
  // the local hooks so commits made inside the container go through
  // the same gates as local dev. ``sudo`` is required for the task
  // installer because /usr/local/bin is root-owned and the
  // postCreateCommand runs as the unprivileged ``vscode`` user.
  "postCreateCommand": "sh -c 'curl -fsSL https://taskfile.dev/install.sh | sudo sh -s -- -d -b /usr/local/bin' && pipx install uv && uv sync --frozen --extra dev && uv run pre-commit install --install-hooks",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        }
      }
    }
  }
}
