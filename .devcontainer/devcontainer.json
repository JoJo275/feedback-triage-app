// Dev container for feedback-triage-app.
//
// Uses Microsoft's Python devcontainer image (Debian + Python 3.13)
// and adds the small set of host tools the project needs at the dev
// surface: uv (env + lockfile), Task (task runner), Docker-in-Docker
// (Postgres compose stack), and the GitHub CLI. Project dependencies
// install on first attach via ``uv sync --frozen --extra dev`` so the
// CI dev-container build (.github/workflows/devcontainer-build.yml)
// can import ``feedback_triage`` immediately.
{
  "name": "feedback-triage-app",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.13-bookworm",
  "features": {
    // Pin the major version of every feature; the underlying images
    // refresh on rebuild without forcing a config edit. ``uv``,
    // ``task``, and Docker are installed via the postCreateCommand
    // because several ghcr.io feature manifests are not publicly
    // resolvable from CI (anonymous ghcr.io requests return 403),
    // and the docker-in-docker feature's apt setup intermittently
    // breaks on upstream Yarn repo GPG-key rotations during CI builds.
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1",
    "UV_LINK_MODE": "copy"
  },
  // ``uv sync`` provisions the project's virtualenv from uv.lock and
  // makes ``feedback_triage`` importable. ``pre-commit install`` wires
  // the local hooks so commits made inside the container go through
  // the same gates as local dev.
  "postCreateCommand": "sh -c 'curl -fsSL https://taskfile.dev/install.sh | sh -s -- -d -b /usr/local/bin' && pipx install uv && uv sync --frozen --extra dev && uv run pre-commit install --install-hooks",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvironment": false,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true
        }
      }
    }
  }
}
