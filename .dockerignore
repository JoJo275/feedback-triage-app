# ──────────────────────────────────────────────────────────────
# .dockerignore
# ──────────────────────────────────────────────────────────────
# Mirror of .containerignore for Docker compatibility.
# Podman reads .containerignore; Docker reads .dockerignore.
# Keep both files in sync.
# ──────────────────────────────────────────────────────────────

# Version control
.git/
.gitignore
.gitmessage.txt

# CI / GitHub
.github/

# Dev container (development only, not for production images)
.devcontainer/

# Virtual environments
.venv/
venv/
env/

# IDE / editor
.vscode/
.idea/

# Python artifacts
__pycache__/
*.py[codz]
*.egg-info/
build/
dist/
sdist/
wheels/

# Testing & coverage
# Note: tests/ is intentionally NOT excluded. The Containerfile doesn't COPY
# tests, so they never end up in the image. Keeping them in the build context
# allows future multi-stage patterns (e.g., a "test" stage that runs pytest
# inside the build). If your build context is enormous, uncomment the line below.
# tests/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Documentation & notes
docs/
site/
mkdocs.yml
mkdocs-hooks/
*.md
!README.md

# Database & runtime data
db/
var/

# Experiments, labels (not needed in image)
experiments/
labels/

# Container / orchestration files (not needed inside the image).
#
# Do NOT exclude `Containerfile` itself: Railway/Railpack snapshots the
# repo and applies `.dockerignore` *before* handing the archive to
# BuildKit, so excluding it makes the platform fail with
# "couldn't locate the dockerfile at path Containerfile in code archive".
# Local `docker build -f Containerfile .` is unaffected because the
# daemon reads the Dockerfile out-of-band; the runtime stage never does
# `COPY . .`, so leaving the file in the context costs nothing.
docker-compose.yml
.containerignore
.dockerignore

# Config files not needed at runtime
Taskfile.yml
.pre-commit-config.yaml
release-please-config.json
codecov.yml
_typos.toml
.markdownlint-cli2.jsonc
.editorconfig
requirements-dev.txt
.repo-doctor.toml
.readthedocs.yaml
.prettierignore
.lycheeignore
.gitattributes
.gitmessage.txt

# OS files
.DS_Store
Thumbs.db

# Secrets / environment (never ship these)
.env
.env.*
!.env.example
